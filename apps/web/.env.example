# =============================================================
# ChoonSim-Talk — Environment Variables
# Copy this file to .env.development and fill in the values.
# Never commit .env.development to version control.
# =============================================================

# --- App ---
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=               # openssl rand -hex 32
SESSION_SECRET=                   # openssl rand -hex 32
ADMIN_EMAILS=                     # 쉼표 구분 관리자 이메일

# --- Database (Turso / libsql) ---
TURSO_DATABASE_URL=               # libsql://your-db.turso.io
TURSO_AUTH_TOKEN=                 # Turso 대시보드에서 발급

# --- Auth — Social OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# --- AI (Gemini) ---
GEMINI_API_KEY=                   # aistudio.google.com에서 발급
GOOGLE_API_KEY=                   # Gemini fallback 키 (선택)
USE_VERCEL_AI_SDK=false

# --- ElevenLabs TTS ---
ELEVENLABS_API_KEY=               # elevenlabs.io에서 발급
ELEVENLABS_MODEL_ID=              # 예: eleven_multilingual_v2
ELEVENLABS_VOICE_ID=              # 기본 음성 ID
ELEVENLABS_VOICE_ID_CHOONSIM=     # 춘심 캐릭터 음성 ID
ELEVENLABS_VOICE_ID_RINA=         # 리나 캐릭터 음성 ID

# --- Payment ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox               # sandbox | live
PAYPAL_WEBHOOK_ID=

TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# --- Cron ---
CRON_SECRET=                      # openssl rand -base64 32

# --- Web Push (VAPID) ---
VAPID_PUBLIC_KEY=                 # npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Solana ---
SOLANA_RPC_URL=https://api.devnet.solana.com
HELIUS_RPC_URL=                   # Helius RPC — DAS API(cNFT 조회) 필수
ZK_COMPRESSION_RPC_URL=           # Helius Photon RPC (ZK Compression + DAS API 겸용)
SOLANA_AGENT_PRIVATE_KEY=         # 서버용 키페어 JSON 배열 [1,2,3,...]
SOLANA_RECEIVER_WALLET=           # CHOCO 결제 수신 지갑 주소
CHOCO_TOKEN_MINT_ADDRESS=         # CHOCO SPL Token-2022 mint 주소
CHOCO_TREASURY_ADDRESS=           # Transfer Fee 수취 지갑
CHOCO_COMPRESSED_MINT_ADDRESS=    # Light Protocol 압축 CHOCO 민트 주소
CHOCO_PER_USER=                   # 유저당 CHOCO 지급량 (기본값 예: 100)
MERKLE_TREE_ADDRESS=              # cNFT Merkle Tree 주소
CHOONSIM_DEFAULT_IMAGE_URI=       # cNFT 기본 이미지 URL

# --- Privy (임베디드 월렛) ---
VITE_PRIVY_APP_ID=                # privy.io 대시보드에서 발급

# --- Misc ---
ROUNDS=                           # bcrypt 해시 라운드 수 (기본값: 10)
